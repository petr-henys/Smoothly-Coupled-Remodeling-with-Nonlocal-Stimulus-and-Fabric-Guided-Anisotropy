{
    "_comment": "Default parameters for femur model (run_model.py). Units: mm, day, MPa, g/cm³",
    
  "material": {
    "E0": 7500.0,
    "nu0": 0.3,
    "n_trab": 2.0,
    "n_cort": 1.3,
    "rho_trab_max": 1.0,
    "rho_cort_min": 1.25,
    "stiff_pE": 1.0,
    "stiff_pG": 1.0
  },
  "density": {
    "rho0": 1.0,
    "rho_min": 0.2,
    "rho_max": 2.0,
    "k_rho_form": 0.05,
    "k_rho_resorb": 0.01,
    "D_rho": 0.01,
    "rho_tissue": 2.0,
    "surface_use": true,
    "surface_A_min": 0.02,
    "surface_S0": 1.0
  },
  "stimulus": {
    "stimulus_power_p": 4.0,
    "psi_ref_trab": 0.003,
    "psi_ref_cort": 0.008,
    "stimulus_tau": 10.0,
    "stimulus_D": 0.5,
    "stimulus_S_max": 1.0,
    "stimulus_kappa": 0.4,
    "stimulus_delta0": 0.1
  },
  "fabric": {
    "fabric_tau": 120.0,
    "fabric_D": 0.01,

    "fabric_gammaF": 1.0,
    "fabric_epsQ": 1e-12,
    "fabric_aniso_eps": 0.0001,
    "fabric_m_min": 0.2,
    "fabric_m_max": 5.0
  },
  "solver": {
    "ksp_type": "minres",
    "pc_type": "gamg",
    "ksp_rtol": 1e-08,
    "ksp_atol": 1e-09,
    "ksp_max_it": 200,
    "ksp_reuse_pc": false,
    "accel_type": "anderson",
    "m": 5,
    "beta": 1.0,
    "lam": 1e-3,
    "coupling_tol": 1e-06,
    "restart_on_stall": 1.1,
    "restart_on_cond": 1e4,
    "step_limit_factor": 1.5,
    "restart_stall_window": 2,
    "restart_stall_patience": 2,
    "max_subiters": 25,
    "outer_stall_window": 4,
    "outer_stall_min_rel_drop": 0.05,
    "outer_stall_patience": 2,
    "rho_anderson_off": 0.3,
    "rho_anderson_on": 0.7,
    "rho_anderson_patience": 3
  },
  "time": {
    "total_time": 500,
    "dt_initial": 25.0,
    "adaptive_dt": false,
    "adaptive_rtol": 0.01,
    "adaptive_atol": 0.001,
    "dt_min": 0.25,
    "dt_max": 10.0,
    "pi_safety": 0.9,
    "pi_growth_max": 3.0,
    "pi_shrink_min": 0.1,
    "pi_k_exp": 1.5,
    "pi_kp": 0.2,
    "pi_ki": 0.4
  },
    "numerics": {
        "quadrature_degree": 4,
        "smooth_eps": 1e-6
    },
    
    "output": {
        "saving_interval": 1,
        "results_dir": ".stiff_results_femur",
        "log_file": "simulation.log"
    },
    
    "geometry": {
        "fix_tag": 1,
        "load_tag": 2
    }
}
