{
    "_comment": "Default parameters for femur model (run_model.py). Units: mm, day, MPa, g/cm³",
    
    "material": {
        "E0": 7500.0,
        "nu0": 0.3,
        "n_trab": 2.0,
        "n_cort": 1.3,
        "rho_trab_max": 1.0,
        "rho_cort_min": 1.25,
        "stiff_pE": 1.0,
        "stiff_pG": 1.0
    },
    
    "density": {
        "rho0": 1.0,
        "rho_min": 0.1,
        "rho_max": 2.0,
        "rho_ref": 1.0,
        "k_rho_form": 0.02,
        "k_rho_resorb": 0.02,
        "D_rho": 0.02,
        "rho_tissue": 2.0,
        "surface_use": true,
        "surface_A_min": 0.02,
        "surface_S0": 1.0
    },
    
    "stimulus": {
        "stimulus_power_p": 4.0,
        "psi_ref": 0.01,
        "stimulus_tau": 25.0,
        "stimulus_D": 1.0,
        "stimulus_S_max": 1.0,
        "stimulus_kappa": 0.5,
        "stimulus_delta0": 0.10
    },
    
    "fabric": {
        "fabric_tau": 50.0,
        "fabric_D": 1.0,
        "fabric_cA": 1.0,
        "fabric_gammaF": 1.0,
        "fabric_epsQ": 1e-12,
        "fabric_aniso_eps": 1e-4,
        "fabric_m_min": 0.2,
        "fabric_m_max": 5.0
    },
    
 "solver": {
        "ksp_type": "minres",
        "pc_type": "gamg",
        "ksp_rtol": 1e-7,
        "ksp_atol": 1e-8,
        "ksp_max_it": 200,
        "ksp_reuse_pc": false,
        "accel_type": "anderson",
        "m": 4,
        "beta": 1.0,
        "lam": 0.01,
        "coupling_tol": 1e-6,
        "restart_on_stall": 1.1,
        "restart_on_cond": 1e5,
        "step_limit_factor": 1.5,
        "restart_stall_window": 2,
        "restart_stall_patience": 2,
        "max_subiters": 25,
        "outer_stall_window": 8,
        "outer_stall_min_rel_drop": 0.05,
        "outer_stall_patience": 2,
        "rho_anderson_off": 0.5
    },
    
    "time": {
        "total_time": 1000.0,
        "dt_initial": 5.0,
        "adaptive_dt": true,
        "adaptive_rtol": 0.01,
        "adaptive_atol": 0.001,
        "dt_min": 1.0,
        "dt_max": 50.0,
        "pi_safety": 0.9,
        "pi_growth_max": 5.0,
        "pi_shrink_min": 0.1,
        "pi_k_exp": 1.5,
        "pi_kp": 0.20,
        "pi_ki": 0.40
    },
    
    "numerics": {
        "quadrature_degree": 4,
        "smooth_eps": 1e-6
    },
    
    "output": {
        "saving_interval": 1,
        "results_dir": ".results",
        "log_file": "simulation.log"
    },
    
    "geometry": {
        "fix_tag": 1,
        "load_tag": 2
    }
}
